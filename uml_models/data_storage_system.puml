@startuml
skinparam classAttributeIconSize 0
title CHMS Data Storage System

class DataStorage {
  - encryptedRecords: Map<String, List<PatientData>>
  - retentionPolicy: RetentionPolicy
  - auditEntries: List<AuditEntry>
  + storeRecord(record: PatientData): void
  + fetchRecords(patientId: String, from: Instant, to: Instant): List<PatientData>
  + saveVersion(recordId: String, version: DataVersion): void
  + purgeExpiredRecords(asOf: Instant): int
}

class PatientData {
  - recordId: String
  - patientId: String
  - metricType: String
  - value: double
  - unit: String
  - recordedAt: Instant
  + addVersion(version: DataVersion): void
  + getLatestVersion(): DataVersion
}

class DataVersion {
  - versionNumber: int
  - revisedValue: double
  - revisedBy: String
  - revisedAt: Instant
  - correctionReason: String
  + isCurrent(): boolean
  + supersedes(versionNumber: int): boolean
}

class DataRetriever {
  - storage: DataStorage
  - accessController: AccessController
  + retrieveLatest(request: AccessRequest, patientId: String, metricType: String): PatientData
  + retrieveHistory(request: AccessRequest, patientId: String, from: Instant, to: Instant): List<PatientData>
}

class AccessController {
  - rolePermissions: Map<String, Set<String>>
  + authorize(request: AccessRequest, patientId: String, action: String): boolean
  + filterForRole(record: PatientData, role: String): PatientData
}

class AccessRequest {
  - requesterId: String
  - requesterRole: String
  - purposeOfUse: String
  - requestedAt: Instant
  + isEmergencyAccess(): boolean
}

class RetentionPolicy {
  - retentionDays: int
  - archiveBeforeDelete: boolean
  - legalHoldPatients: Set<String>
  + shouldArchive(record: PatientData, asOf: Instant): boolean
  + shouldDelete(record: PatientData, asOf: Instant): boolean
}

class AuditEntry {
  - entryId: String
  - requesterId: String
  - action: String
  - patientId: String
  - recordedAt: Instant
  + describe(): String
}

DataStorage *-- "0..*" PatientData : stores
PatientData *-- "1..*" DataVersion : version history
DataRetriever --> "1" DataStorage : queries
DataRetriever --> "1" AccessController : authorizes via
DataRetriever --> "1" AccessRequest : uses
DataStorage --> "1" RetentionPolicy : applies
DataStorage o-- "0..*" AuditEntry : records access
AccessController ..> "1" AccessRequest : evaluates
RetentionPolicy ..> "0..*" PatientData : governs lifecycle

@enduml
