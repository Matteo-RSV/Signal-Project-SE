@startuml
skinparam classAttributeIconSize 0
title CHMS Data Storage System

class DataStorage {
  - patientRecords: Map<String, List<PatientData>>
  - keepData: RetentionPolicy
  - accessLog: List<AuditEntry>
  + saveRecord(record: PatientData): void
  + getRecords(patientId: String, from: Instant, to: Instant): List<PatientData>
  + saveCorrection(recordId: String, version: DataVersion): void
  + removeExpiredRecords(asOf: Instant): int
}

class PatientData {
  - recordId: String
  - patientId: String
  - metricType: String
  - value: double
  - unit: String
  - recordedAt: Instant
  + addVersion(version: DataVersion): void
  + getNewestVersion(): DataVersion
}

class DataVersion {
  - versionNumber: int
  - correctedValue: double
  - correctedBy: String
  - correctedAt: Instant
  - reason: String
  + isLatest(): boolean
  + replaces(versionNumber: int): boolean
}

class DataRetriever {
  - storage: DataStorage
  - accessController: AccessController
  + getLatestRecord(request: AccessRequest, patientId: String, metricType: String): PatientData
  + getHistory(request: AccessRequest, patientId: String, from: Instant, to: Instant): List<PatientData>
}

class AccessController {
  - allowedActions: Map<String, Set<String>>
  + allow(request: AccessRequest, patientId: String, action: String): boolean
  + filterForRole(record: PatientData, role: String): PatientData
}

class AccessRequest {
  - requesterId: String
  - requesterRole: String
  - purposeOfUse: String
  - requestedAt: Instant
  + isEmergency(): boolean
}

class RetentionPolicy {
  - retentionDays: int
  - archiveFirst: boolean
  - legalHoldPatients: Set<String>
  + shouldArchive(record: PatientData, asOf: Instant): boolean
  + shouldDelete(record: PatientData, asOf: Instant): boolean
}

class AuditEntry {
  - entryId: String
  - requesterId: String
  - action: String
  - patientId: String
  - loggedAt: Instant
  + toText(): String
}

DataStorage *-- "0..*" PatientData : stores
PatientData *-- "1..*" DataVersion : version history
DataRetriever --> "1" DataStorage : queries
DataRetriever --> "1" AccessController : authorizes via
DataRetriever --> "1" AccessRequest : uses
DataStorage --> "1" RetentionPolicy : applies
DataStorage o-- "0..*" AuditEntry : records access
AccessController ..> "1" AccessRequest : evaluates
RetentionPolicy ..> "0..*" PatientData : governs lifecycle

@enduml
