@startuml
skinparam classAttributeIconSize 0
title CHMS Data Access Layer

interface DataListener {
  + open(endpoint: String): void
  + readMessage(): String
  + close(): void
}

class TCPDataListener {
  - host: String
  - port: int
  + open(endpoint: String): void
  + readMessage(): String
  + close(): void
}

class WebSocketDataListener {
  - uri: String
  - channel: String
  + open(endpoint: String): void
  + readMessage(): String
  + close(): void
}

class FileDataListener {
  - filePath: String
  - lineNumber: long
  + open(endpoint: String): void
  + readMessage(): String
  + close(): void
}

interface DataParser {
  + parse(rawText: String): IncomingReading
  + supports(format: String): boolean
}

class JsonDataParser {
  + parse(rawText: String): IncomingReading
  + supports(format: String): boolean
}

class CsvDataParser {
  + parse(rawText: String): IncomingReading
  + supports(format: String): boolean
}

class DataSourceAdapter {
  - listener: DataListener
  - parser: DataParser
  - receiver: MeasurementReceiver
  + start(endpoint: String, format: String): void
  + nextReading(): IncomingReading
  + deliver(reading: IncomingReading): void
}

class IncomingReading {
  - patientId: String
  - metricName: String
  - value: double
  - unit: String
  - recordedAt: Instant
  + isValid(): boolean
}

interface MeasurementReceiver {
  + accept(reading: IncomingReading): void
}

DataListener <|.. TCPDataListener
DataListener <|.. WebSocketDataListener
DataListener <|.. FileDataListener
DataParser <|.. JsonDataParser
DataParser <|.. CsvDataParser
DataSourceAdapter *-- "1" DataListener : configures
DataSourceAdapter *-- "1" DataParser : uses
DataParser --> "1" IncomingReading : produces
DataSourceAdapter --> "1" MeasurementReceiver : forwards to
DataSourceAdapter ..> "0..*" IncomingReading : validates

@enduml
