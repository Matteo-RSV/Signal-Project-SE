@startuml
skinparam classAttributeIconSize 0
title CHMS Data Access Layer

interface DataListener {
  + connect(endpoint: String): void
  + receive(): String
  + close(): void
}

class TCPDataListener {
  - host: String
  - port: int
  + connect(endpoint: String): void
  + receive(): String
  + close(): void
}

class WebSocketDataListener {
  - uri: String
  - subscribedChannel: String
  + connect(endpoint: String): void
  + receive(): String
  + close(): void
}

class FileDataListener {
  - filePath: String
  - cursor: long
  + connect(endpoint: String): void
  + receive(): String
  + close(): void
}

interface DataParser {
  + parse(rawMessage: String): ParsedMeasurement
  + supports(format: String): boolean
}

class JsonDataParser {
  + parse(rawMessage: String): ParsedMeasurement
  + supports(format: String): boolean
}

class CsvDataParser {
  + parse(rawMessage: String): ParsedMeasurement
  + supports(format: String): boolean
}

class DataSourceAdapter {
  - listener: DataListener
  - parser: DataParser
  - receiver: CHMSInputPort
  + ingest(endpoint: String, format: String): void
  + readAndParse(): ParsedMeasurement
  + submitMeasurement(measurement: ParsedMeasurement): void
}

class ParsedMeasurement {
  - patientId: String
  - metricName: String
  - value: double
  - unit: String
  - observedAt: Instant
  + isValid(): boolean
}

interface CHMSInputPort {
  + acceptMeasurement(measurement: ParsedMeasurement): void
}

DataListener <|.. TCPDataListener
DataListener <|.. WebSocketDataListener
DataListener <|.. FileDataListener
DataParser <|.. JsonDataParser
DataParser <|.. CsvDataParser
DataSourceAdapter *-- "1" DataListener : configures
DataSourceAdapter *-- "1" DataParser : uses
DataParser --> "1" ParsedMeasurement : produces
DataSourceAdapter --> "1" CHMSInputPort : forwards to
DataSourceAdapter ..> "0..*" ParsedMeasurement : validates

@enduml
