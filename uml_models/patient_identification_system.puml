@startuml
skinparam classAttributeIconSize 0
title CHMS Patient Identification System

class PatientIdentifier {
  - minimumScore: double
  + findMatch(token: IdentifierToken, details: DemographicProfile, candidates: List<HospitalPatient>): MatchResult
  + compareDetails(details: DemographicProfile, patient: HospitalPatient): double
  + checkToken(token: IdentifierToken): boolean
}

class HospitalPatient {
  - patientId: String
  - fullName: String
  - medicalRecordNumber: String
  - historyNote: String
  - admissionStatus: String
  - dateOfBirth: LocalDate
  + isActive(): boolean
  + getShortHistory(): String
}

class IdentityManager {
  - patientRepository: PatientRepository
  - identifier: PatientIdentifier
  - accessPolicy: AccessPolicy
  - anomalyLog: List<IdentityAnomaly>
  + matchIncomingPatient(token: IdentifierToken, details: DemographicProfile): MatchResult
  + getPatientRecord(patientId: String, requesterRole: String): HospitalPatient
  + logAnomaly(anomaly: IdentityAnomaly): void
}

class DemographicProfile {
  - fullName: String
  - dateOfBirth: LocalDate
  - sexAtBirth: String
  - wardCode: String
  + matches(patient: HospitalPatient): boolean
}

class MatchResult {
  - score: double
  - matchStatus: String
  - matchedPatientId: String
  + isAccepted(limit: double): boolean
  + needsReview(): boolean
}

class IdentityAnomaly {
  - anomalyId: String
  - type: String
  - notes: String
  - detectedAt: Instant
  - severity: String
  + sendToReview(teamId: String): void
  + close(note: String): void
}

class IdentifierToken {
  - tokenType: String
  - tokenValue: String
  - issuer: String
  - issuedAt: Instant
  + isUsable(asOf: Instant): boolean
}

class PatientRepository {
  - patients: Map<String, HospitalPatient>
  + findPossiblePatients(token: IdentifierToken, details: DemographicProfile): List<HospitalPatient>
  + getPatient(patientId: String): HospitalPatient
}

class AccessPolicy {
  - rolePermissions: Map<String, Set<String>>
  + canOpenRecord(requesterRole: String, patientId: String): boolean
  + hideSensitiveFields(patient: HospitalPatient): HospitalPatient
}

IdentityManager *-- "1" PatientIdentifier : uses
IdentityManager --> "1" PatientRepository : retrieves from
IdentityManager --> "1" AccessPolicy : authorizes via
IdentityManager *-- "0..*" IdentityAnomaly : tracks
PatientRepository o-- "0..*" HospitalPatient : stores
PatientIdentifier ..> "1" IdentifierToken : validates
PatientIdentifier ..> "1" DemographicProfile : compares
PatientIdentifier --> "1" MatchResult : produces
MatchResult --> "0..1" HospitalPatient : matched patient
HospitalPatient *-- "1" DemographicProfile : identity traits

@enduml
