@startuml
skinparam classAttributeIconSize 0
title CHMS Patient Identification System

class PatientIdentifier {
  - minimumConfidence: double
  + matchPatient(token: IdentifierToken, profile: DemographicProfile, candidates: List<HospitalPatient>): MatchResult
  + compareProfile(profile: DemographicProfile, patient: HospitalPatient): double
  + validateToken(token: IdentifierToken): boolean
}

class HospitalPatient {
  - patientId: String
  - fullName: String
  - medicalRecordNumber: String
  - medicalHistorySummary: String
  - admissionStatus: String
  - dateOfBirth: LocalDate
  + isActiveAdmission(): boolean
  + getClinicalSummary(): String
}

class IdentityManager {
  - patientRepository: PatientRepository
  - identifier: PatientIdentifier
  - accessPolicy: AccessPolicy
  - anomalies: List<IdentityAnomaly>
  + resolveIdentity(token: IdentifierToken, profile: DemographicProfile): MatchResult
  + getPatientInfo(patientId: String, requesterRole: String): HospitalPatient
  + recordAnomaly(anomaly: IdentityAnomaly): void
}

class DemographicProfile {
  - fullName: String
  - dateOfBirth: LocalDate
  - sexAtBirth: String
  - wardCode: String
  + matches(patient: HospitalPatient): boolean
}

class MatchResult {
  - confidenceScore: double
  - matchStatus: String
  - matchedPatientId: String
  + isAccepted(threshold: double): boolean
  + isAmbiguous(): boolean
}

class IdentityAnomaly {
  - anomalyId: String
  - anomalyType: String
  - details: String
  - detectedAt: Instant
  - severity: String
  + assignForReview(teamId: String): void
  + close(resolutionNote: String): void
}

class IdentifierToken {
  - tokenType: String
  - tokenValue: String
  - issuer: String
  - issuedAt: Instant
  + isTrusted(asOf: Instant): boolean
}

class PatientRepository {
  - patientIndex: Map<String, HospitalPatient>
  + findCandidates(token: IdentifierToken, profile: DemographicProfile): List<HospitalPatient>
  + findByPatientId(patientId: String): HospitalPatient
}

class AccessPolicy {
  - rolePermissions: Map<String, Set<String>>
  + canViewPatient(requesterRole: String, patientId: String): boolean
  + maskPatient(patient: HospitalPatient): HospitalPatient
}

IdentityManager *-- "1" PatientIdentifier : uses
IdentityManager --> "1" PatientRepository : retrieves from
IdentityManager --> "1" AccessPolicy : authorizes via
IdentityManager *-- "0..*" IdentityAnomaly : tracks
PatientRepository o-- "0..*" HospitalPatient : stores
PatientIdentifier ..> "1" IdentifierToken : validates
PatientIdentifier ..> "1" DemographicProfile : compares
PatientIdentifier --> "1" MatchResult : produces
MatchResult --> "0..1" HospitalPatient : matched patient
HospitalPatient *-- "1" DemographicProfile : identity traits

@enduml
