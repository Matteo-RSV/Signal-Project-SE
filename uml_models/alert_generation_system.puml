@startuml
skinparam classAttributeIconSize 0
title CHMS Alert Generation System

class AlertGenerator {
  - dataStorage: DataStorage
  - patientIdentifier: PatientIdentifier
  - alertManager: AlertManager
  + evaluateRealTimeData(patientId: String, metricName: String, value: double, observedAt: Instant): Alert
  + loadThresholdProfile(patientId: String): ThresholdProfile
  - buildAlert(snapshot: PatientDataSnapshot, rule: AlertRule): Alert
}

class Alert {
  - alertId: String
  - severity: String
  - condition: String
  - status: String
  - createdAt: Instant
  + acknowledge(userId: String): void
  + resolve(resolvedAt: Instant): void
}

class AlertManager {
  - activeAlerts: Map<String, Alert>
  - routingTargets: List<String>
  + registerAlert(alert: Alert): void
  + routeAlert(alert: Alert, destinationRole: String): void
  + closeAlert(alertId: String): void
}

class AlertRule {
  - metricName: String
  - lowerLimit: double
  - upperLimit: double
  - minimumDurationSec: int
  + isBreached(snapshot: PatientDataSnapshot, profile: ThresholdProfile): boolean
}

class ThresholdProfile {
  - patientId: String
  - thresholdVersion: int
  - customLimits: Map<String, String>
  + getLimit(metricName: String): String
  + updateLimit(metricName: String, ruleExpression: String): void
}

class PatientDataSnapshot {
  - patientId: String
  - metricName: String
  - value: double
  - observedAt: Instant
  + isRecent(referenceTime: Instant): boolean
}

class PatientIdentifier {
  + resolvePatient(patientId: String): HospitalPatient
  + verifyMonitoringAssignment(patientId: String): boolean
}

class HospitalPatient {
  - patientId: String
  - monitoringStatus: String
  - wardLocation: String
  + isAdmitted(): boolean
}

class DataStorage {
  + getLatestSnapshot(patientId: String, metricName: String): PatientDataSnapshot
  + storeAlert(alert: Alert): void
  + loadThresholdProfile(patientId: String): ThresholdProfile
}

AlertGenerator --> "1" DataStorage : reads and persists
AlertGenerator --> "1" PatientIdentifier : verifies patient
AlertGenerator --> "1" AlertManager : delegates routing
AlertGenerator --> "1..*" AlertRule : evaluates
AlertRule ..> "1" ThresholdProfile : applies
AlertManager *-- "0..*" Alert : manages lifecycle
DataStorage o-- "0..*" PatientDataSnapshot : stores
HospitalPatient *-- "1" ThresholdProfile : owns
Alert --> "1" HospitalPatient : concerns

@enduml
