@startuml
skinparam classAttributeIconSize 0
title CHMS Alert Generation System

class AlertGenerator {
  - storage: DataStorage
  - patientLookup: PatientIdentifier
  - manager: AlertManager
  + checkReading(patientId: String, metricName: String, value: double, observedAt: Instant): Alert
  + getThresholds(patientId: String): ThresholdProfile
  - createAlert(reading: PatientDataSnapshot, rule: AlertRule): Alert
}

class Alert {
  - alertId: String
  - severity: String
  - condition: String
  - status: String
  - createdAt: Instant
  + acknowledge(userId: String): void
  + resolve(resolvedAt: Instant): void
}

class AlertManager {
  - openAlerts: Map<String, Alert>
  - routeList: List<String>
  + addAlert(alert: Alert): void
  + sendAlert(alert: Alert, targetRole: String): void
  + resolveAlert(alertId: String): void
}

class AlertRule {
  - metricName: String
  - lowerLimit: double
  - upperLimit: double
  - minimumDurationSec: int
  + checkThreshold(reading: PatientDataSnapshot, profile: ThresholdProfile): boolean
}

class ThresholdProfile {
  - patientId: String
  - versionNumber: int
  - limits: Map<String, String>
  + getRule(metricName: String): String
  + changeRule(metricName: String, ruleText: String): void
}

class PatientDataSnapshot {
  - patientId: String
  - metricName: String
  - value: double
  - observedAt: Instant
  + isFresh(now: Instant): boolean
}

class PatientIdentifier {
  + getPatient(patientId: String): HospitalPatient
  + isCurrentAssignment(patientId: String): boolean
}

class HospitalPatient {
  - patientId: String
  - monitoringStatus: String
  - ward: String
  + isAdmitted(): boolean
}

class DataStorage {
  + readLatestReading(patientId: String, metricName: String): PatientDataSnapshot
  + saveAlert(alert: Alert): void
  + getThresholdProfile(patientId: String): ThresholdProfile
}

AlertGenerator --> "1" DataStorage : reads and persists
AlertGenerator --> "1" PatientIdentifier : verifies patient
AlertGenerator --> "1" AlertManager : delegates routing
AlertGenerator --> "1..*" AlertRule : evaluates
AlertRule ..> "1" ThresholdProfile : applies
AlertManager *-- "0..*" Alert : manages lifecycle
DataStorage o-- "0..*" PatientDataSnapshot : stores
HospitalPatient *-- "1" ThresholdProfile : owns
Alert --> "1" HospitalPatient : concerns

@enduml
